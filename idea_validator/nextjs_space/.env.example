# Copy to .env and set real values. Never commit .env.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?connect_timeout=15"

# Site URL (used by NextAuth, emails, sitemap). Production: https://your-project.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# --- LLM (OpenAI-compatible Chat Completions) ---
# Defaults target Abacus-hosted chat; for OpenAI set:
#   AI_API_BASE_URL=https://api.openai.com/v1
#   AI_API_KEY=sk-...
#   AI_MODEL=gpt-4o-mini
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=
# Legacy alias for AI_API_KEY (still works if AI_API_KEY is unset)
ABACUSAI_API_KEY=

# Abacus-only: HTML→PDF and hosted notification email (optional if you use alternatives)
ABACUS_DEPLOYMENT_TOKEN=
# PDF: unset = use Abacus HTML→PDF when token present; PDF_EXPORT=off disables export endpoints
PDF_EXPORT=

# Weekly digest email — pick ONE path:
# (A) Resend (recommended self-hosted): https://resend.com
RESEND_API_KEY=
RESEND_FROM=
# (B) Abacus sendNotificationEmail (legacy)
WEB_APP_ID=
NOTIF_ID_WEEKLY_MARKET_SIGNALS_DIGEST=

# POST /api/cron/market-signals-digest JSON body must include { "secret": "<same value>" }
CRON_SECRET=

# Optional: load Abacus appllm-lib.js in <head> (default: do not load)
ABACUS_APPLLM_SCRIPT=

# Canonical URL fallback when NEXTAUTH_URL is unset (robots/sitemap build-time)
SITE_URL=

# AWS S3 — presigned logo uploads (/api/upload/presigned). Bucket policy should allow public GET for keys under .../public/uploads/ when isPublic is true.
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
