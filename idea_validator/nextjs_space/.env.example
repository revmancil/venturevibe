# Copy to .env and set real values. Never commit .env.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?connect_timeout=15"

# Site URL (used by NextAuth, emails, sitemap). Must match the URL in your browser exactly.
# Local: http://localhost:3000. Vercel production: https://www.venturevibe.pro
NEXTAUTH_URL=http://localhost:3000
# Required in production (Vercel). Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Supabase on Vercel: use the **Session pooler** or **Transaction pooler** URI from Supabase → Connect (not the direct db.*.supabase.co URL).
# Transaction pooler example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Run migrations once from your machine (direct URL): npm run db:migrate:deploy

# Show "Fill demo email & password" on /auth/login (credentials: lib/demo-auth.ts). In dev or when this is true, the demo user is also auto-created on first successful demo login (no seed required).
NEXT_PUBLIC_SHOW_DEMO_LOGIN=
# Server-only: allow demo user auto-create on login without showing the fill button in the UI
ALLOW_DEMO_LOGIN=

# --- LLM (OpenAI-compatible Chat Completions) — REQUIRED for all validation tools ---
# Without AI_API_KEY, /api/validation/* returns 503. Check /api/llm/health after deploy.
# Defaults target Abacus-hosted chat; for OpenAI set:
#   AI_API_BASE_URL=https://api.openai.com/v1
#   AI_API_KEY=sk-...
#   AI_MODEL=gpt-4o-mini
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=
# Legacy alias for AI_API_KEY (still works if AI_API_KEY is unset)
ABACUSAI_API_KEY=

# Abacus-only: HTML→PDF and hosted notification email (optional if you use alternatives)
ABACUS_DEPLOYMENT_TOKEN=
# PDF: unset = use Abacus HTML→PDF when token present; PDF_EXPORT=off disables export endpoints
PDF_EXPORT=

# Weekly digest email — pick ONE path:
# (A) Resend (recommended self-hosted): https://resend.com
RESEND_API_KEY=
RESEND_FROM=
# (B) Abacus sendNotificationEmail (legacy)
WEB_APP_ID=
NOTIF_ID_WEEKLY_MARKET_SIGNALS_DIGEST=

# POST /api/cron/market-signals-digest JSON body must include { "secret": "<same value>" }
CRON_SECRET=

# Optional: load Abacus appllm-lib.js in <head> (default: do not load)
ABACUS_APPLLM_SCRIPT=

# Canonical URL for metadata/sitemap when NEXTAUTH_URL is unset. Production: https://www.venturevibe.pro
SITE_URL=

# AWS S3 — presigned logo uploads (/api/upload/presigned). Bucket policy should allow public GET for keys under .../public/uploads/ when isPublic is true.
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_FOLDER_PREFIX=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
